            <img
              class="object-fit-contain mb-3 mx-auto"
              src="images/content/logo.png"
              width="64"
              height="64"
              alt="team"
            />
            <div class="text-primary h6 text-center">Vysočina Gladiators</div>
          </div>
          <div class="col-lg col-sm-auto col">
            <img
              class="object-fit-contain mb-3 mx-auto"
