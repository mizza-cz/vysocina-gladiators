<div class="matchBoard">
  <div class="row g-6 align-items-center">
    <div class="col-xl-4 col-lg-3">
      <ul
        class="text-center d-flex flex-lg-column gap-2 text-secondary text-regular-sm justify-content-center align-items-center"
      >
        <li>Stadion Vysočina</li>
        <li>·</li>
        <li>5. ledna 2025</li>
        <li>·</li>
        <li>17:00</li>
      </ul>
    </div>
    <div class="col-xl-4 col-lg-6">
      <div class="matchBoard-content">
        <div class="row justify-content-center flex-nowrap">
